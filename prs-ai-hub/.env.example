# Groq API
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# Fallback chain if primary fails (rate limit, timeout, bad JSON). GPT-OSS 120B is best OSS fallback on Groq.
GROQ_FALLBACK_MODELS=openai/gpt-oss-120b,openai/gpt-oss-20b,llama-3.1-8b-instant
GROQ_MAX_TOKENS=4096

# Database
DATABASE_URL=postgresql+asyncpg://prs_user:prs_password@localhost:5432/prs_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Service URLs (docker-compose overrides these)
INTAKE_AGENT_URL=http://localhost:8001
CONTRACT_AGENT_URL=http://localhost:8002
SKU_AGENT_URL=http://localhost:8003
CCR_AGENT_URL=http://localhost:8004
CONTRACT_INTELLIGENCE_DIR=../data/Contract intelligence

# Gateway
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
